platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Enforce minimum deployment target to suppress IPHONEOS_DEPLOYMENT_TARGET warnings
      if config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'].to_f < 13.0
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      end
      # Suppress all third-party pod warnings (we cannot fix pod source code)
      config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
      config.build_settings['SWIFT_SUPPRESS_WARNINGS'] = 'YES'
      # Disable module verifier to prevent clean build failures with Flutter pods
      config.build_settings['ENABLE_MODULE_VERIFIER'] = 'NO'
      # Suppress 'dummy.o has no symbols' libtool warning
      config.build_settings['OTHER_LIBTOOLFLAGS'] = '-no_warning_for_no_symbols'
      # Suppress duplicate library linker warnings (-lc++ from multiple pods)
      ldflags = config.build_settings['OTHER_LDFLAGS']
      no_dup_flag = '-Wl,-no_warn_duplicate_libraries'
      if ldflags.is_a?(Array)
        config.build_settings['OTHER_LDFLAGS'] = ldflags | [no_dup_flag]
      elsif ldflags.is_a?(String)
        unless ldflags.include?(no_dup_flag)
          config.build_settings['OTHER_LDFLAGS'] = "#{ldflags} #{no_dup_flag}"
        end
      else
        config.build_settings['OTHER_LDFLAGS'] = ['$(inherited)', no_dup_flag]
      end
    end

    # Suppress 'Create Symlinks to Header Folders' script phase warnings
    target.shell_script_build_phases.each do |phase|
      if phase.name == 'Create Symlinks to Header Folders'
        phase.always_out_of_date = '1'
      end
    end
  end
end
